import matplotlib.pyplot as plt
from collections import Counter
for disease_name,disease_dataframe in data_set.groupby('Disease'):
  symptoms_dataframe = disease_dataframe.drop('Disease',axis=1)
  flat_symp_df = symptoms_dataframe.to_numpy().flatten()
  series_symp_df = pd.Series(flat_symp_df)
  series_symp_df = series_symp_df.dropna()
  dictionary = Counter(series_symp_df)
  #print(dictionary)
  labels_var = dictionary.keys()
  labels_list = list(labels_var)
  labels_length = len(labels_list)
  position = range(labels_length)
  count_var = dictionary.values()
  count_list = list(count_var)
  disease_list.append(disease_name)
  height = count_list
  width = 0.3
  plt.figure(figsize=(10,5))
  plt.bar(position,height,width,color='salmon')
  plt.xticks(position,labels_list,rotation=45)
  plt.xlabel(f"Symptoms of {disease_name}")
  plt.ylabel('Count of symptoms')
  plt.show()



  




